# Speech-to-Text Configuration
# Copy to .env and edit paths to match your setup
# Run `bun run setup` to auto-populate this

# ─── Whisper.cpp ──────────────────────────────────────────────────────────────
# Path to the compiled whisper.cpp main binary
WHISPER_BIN=/home/keith/.local/share/stt/whisper.cpp/build/bin/whisper-cli

# Whisper model file (large-v3 recommended for RTX 3080 10GB)
# Models in order of accuracy (and VRAM/speed trade-off):
#   ggml-tiny.bin      ~75MB   — fastest
#   ggml-base.bin      ~145MB  — fast
#   ggml-small.bin     ~466MB  — good balance
#   ggml-medium.bin    ~1.5GB  — great accuracy
#   ggml-large-v3.bin  ~3GB    — best accuracy  ← recommended
WHISPER_MODEL=/home/keith/.local/share/stt/models/ggml-large-v3.bin

# ─── LLM (Ollama) ─────────────────────────────────────────────────────────────
# Ollama model for text cleanup (must be pulled: ollama pull <model>)
# Recommended for RTX 3080 10GB:
#   llama3.2:3b  — ~2GB VRAM, ~500 tok/s, great for cleanup  ← default
#   llama3.1:8b  — ~5GB VRAM, ~150 tok/s, higher quality
OLLAMA_MODEL=llama3.2:3b

# Ollama API URL (default works for local Ollama)
OLLAMA_URL=http://localhost:11434

# Set to "true" to skip LLM cleanup and use raw Whisper output
SKIP_LLM=false

# ─── Audio input device ───────────────────────────────────────────────────────
# Leave blank to use the system default microphone.
# Run `bun run devices` to list available input devices.
# Example (Blue Yeti):
#   AUDIO_DEVICE=alsa_input.usb-Blue_Microphones_Yeti_Stereo_Microphone_FST_2018_10_10_45294-00.analog-stereo
AUDIO_DEVICE=

# ─── Output ────────────────────────────────────────────────────────────────────
# How to deliver the transcribed text to the focused window:
#   type       — xdotool type (works everywhere, slightly slower)
#   clipboard  — write to clipboard + simulate Ctrl+V (faster)
OUTPUT_METHOD=type

# ─── Recording archive ────────────────────────────────────────────────────────
# Directory to save recordings and transcripts. Each session is saved in a
# timestamped subdirectory: <SAVE_DIR>/YYYY-MM-DD_HH-MM-SS/
#   audio.wav               — raw recording
#   raw_transcription.txt   — whisper output before LLM cleanup
#   transcription.txt       — final text (after LLM, or same as raw if SKIP_LLM)
# Leave blank to disable saving.
SAVE_DIR=/tmp/speech_transcriber_sessions

# ─── dwm Status Bar ───────────────────────────────────────────────────────────
# Script that prints the full status bar text (piped to xsetroot on each state
# change so the bar updates immediately without waiting for the slow polling loop).
# Leave blank to disable immediate refresh (relies on your existing bar loop).
STATUS_BAR_PRINT_SCRIPT=/home/keith/keith_apps/dwm/status_bar/print_helper.js
