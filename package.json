{
  "name": "speech_transcriber",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "daemon": "bun run src/daemon.ts",
    "toggle": "bun run src/toggle.ts",
    "devices": "bun run src/devices.ts",
    "setup": "bash scripts/setup.sh",
    "last_stt": "bun run src/last_stt.ts",
    "logs": "journalctl  --no-pager --user -u stt-daemon -n 50"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "dotenv": "^17.3.1"
  }
}
